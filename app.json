{
  "expo": {
    "name": "Briefcase",
    "slug": "briefcase",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "briefcase",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "me.echovault.briefcase",
      "usesAppleSignIn": true,
      "buildNumber": "8"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B4332",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "me.echovault.briefcase"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1B4332",
          "dark": {
            "backgroundColor": "#1A1D23"
          }
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-secure-store"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "revenueCatApiKey": "",
      "revenueCatTestApiKey": ""
    }
  }
}
